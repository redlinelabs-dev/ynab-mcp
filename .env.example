# YNAB Personal Access Token — required.
# Create one in YNAB: Account Settings > Developer Settings > New Token.
YNAB_TOKEN=your-personal-access-token

# Default budget for tools that omit `budget_id`.
# A budget UUID, or an alias: "last-used" or "default". Defaults to "last-used".
YNAB_BUDGET_ID=last-used

# Optional: expose only some toolset groups (comma-separated), or "all" (default).
# Groups: budgets, accounts, categories, transactions, months, payees
# YNAB_TOOLSETS=budgets,accounts,transactions

# Optional: expose only non-mutating (read) tools.
# YNAB_READ_ONLY=true
