# ─────────────────────────────────────────────────────────────────────────────
# Remote server (dist/server.js — the Docker/homelab product). See docs/DEPLOY.md.
# ─────────────────────────────────────────────────────────────────────────────

# Required. The external HTTPS base URL clients reach this server at, and the
# OAuth issuer. Typically a Tailscale name or your reverse-proxy domain.
PUBLIC_URL=https://ynab.your-tailnet.ts.net

# Required. Your YNAB OAuth application credentials (YNAB > Developer Settings).
# Register the redirect URI as ${PUBLIC_URL}/callback.
YNAB_CLIENT_ID=your-ynab-oauth-client-id
YNAB_CLIENT_SECRET=your-ynab-oauth-client-secret

# Required. AES-256 key for sealing YNAB tokens at rest. Generate with:
#   openssl rand -base64 32
ENCRYPTION_KEY=base64-of-32-random-bytes

# Optional. Overrides the default ${PUBLIC_URL}/callback.
# YNAB_REDIRECT_URI=https://ynab.your-tailnet.ts.net/callback

# Optional. SQLite file path (mount a volume here). Default ./data/ynab-mcp.db.
# DATABASE_PATH=./data/ynab-mcp.db

# Optional. Listen port. Default 8080.
# PORT=8080

# ─────────────────────────────────────────────────────────────────────────────
# Local stdio server (dist/index.js — `npm run start:stdio`, dev/personal use).
# ─────────────────────────────────────────────────────────────────────────────

# Personal Access Token (YNAB > Account Settings > Developer Settings > New Token).
YNAB_TOKEN=your-personal-access-token

# Default budget for tools that omit `budget_id`: a UUID or "last-used"/"default".
YNAB_BUDGET_ID=last-used

# Optional: expose only some toolset groups (comma-separated), or "all" (default).
# YNAB_TOOLSETS=budgets,accounts,transactions

# Optional: expose only non-mutating (read) tools.
# YNAB_READ_ONLY=true
