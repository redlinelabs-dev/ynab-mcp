# ─────────────────────────────────────────────────────────────────────────────
# Preferred deploy — docker-compose.yml (GHCR image + Tailscale sidecar).
# One app dir = this .env + docker-compose.yml. See docs/DEPLOY.md.
# ─────────────────────────────────────────────────────────────────────────────

# Tailscale machine FQDN this server is served at (must match `hostname:` in the
# compose → here `ynab`). OAuth issuer + redirect base derive from it.
TS_HOSTNAME=ynab.your-tailnet.ts.net

# Tailscale auth key (https://login.tailscale.com/admin/settings/keys). Reusable
# or ephemeral both work; TS_AUTH_ONCE means it's only used on first start.
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx

# Your YNAB OAuth application (YNAB > Account Settings > Developer Settings).
# Register the redirect URI as https://${TS_HOSTNAME}/callback.
YNAB_CLIENT_ID=your-ynab-oauth-client-id
YNAB_CLIENT_SECRET=your-ynab-oauth-client-secret

# AES-256 key sealing YNAB tokens at rest. Generate: openssl rand -base64 32
ENCRYPTION_KEY=base64-of-32-random-bytes

# Host directory for persisted state (snapshot this on TrueNAS/ZFS). The compose
# bind-mounts ${DATA_DIR}/data (SQLite db) and ${DATA_DIR}/tailscale (ts state).
DATA_DIR=/mnt/HomeServer/Vault/Apps/ynab-mcp

# uid:gid the app runs as — must own ${DATA_DIR}/data, else it can't create its
# SQLite file. Default 1000 (the image's `node` user). Set these to your dataset's
# owner (find it: `ls -n ${DATA_DIR}`), or `chown -R 1000:1000 ${DATA_DIR}/data`.
PUID=1000
PGID=1000

# ─────────────────────────────────────────────────────────────────────────────
# Bare server (no Tailscale sidecar) — read directly by dist/server.js. Only
# needed if you run the image/process without the compose above.
# ─────────────────────────────────────────────────────────────────────────────
# PUBLIC_URL=https://ynab.your-tailnet.ts.net
# DATABASE_PATH=/app/data/ynab-mcp.db
# PORT=8080

# ─────────────────────────────────────────────────────────────────────────────
# Local stdio server (dist/index.js — `npm run start:stdio`, dev/personal use).
# ─────────────────────────────────────────────────────────────────────────────
# YNAB_TOKEN=your-personal-access-token
# YNAB_BUDGET_ID=last-used
# YNAB_TOOLSETS=budgets,accounts,transactions
# YNAB_READ_ONLY=true
