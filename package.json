{
  "name": "@redlinelabs/ynab-mcp",
  "version": "0.2.0",
  "private": true,
  "description": "MCP server for YNAB (You Need A Budget) — budgets, accounts, categories, transactions, and more",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/redlinelabs-dev/ynab-mcp.git"
  },
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsgo",
    "start": "node dist/server.js",
    "start:stdio": "node dist/index.js",
    "dev": "tsgo --watch",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsgo --noEmit && oxlint && oxfmt --check && vitest run",
    "fix": "oxlint --fix && oxfmt",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/express": "^5.0.6",
    "@types/node": "latest",
    "@typescript/native-preview": "latest",
    "husky": "^9.1.7",
    "oxfmt": "latest",
    "oxlint": "latest",
    "vitest": "^4.1.8",
    "wrangler": "^4.98.0"
  },
  "engines": {
    "node": ">=24"
  }
}
